# ---- client-side (client/ask.py) ----------------------------------------

# Used ONLY for the speech-to-text call to OpenAI's transcription API.
# The deployed crew never sees this key — on CrewAI AMP its LLM access comes
# from your organization's OpenAI connection, so the deployment itself needs
# NO OpenAI key. (Alternative: put the key in ~/.openai-key instead.)
OPENAI_API_KEY=sk-...

# Both values are shown on your deployment's page in CrewAI AMP after you
# deploy. Every deployment has its OWN url and its OWN bearer token.
CREWAI_DEPLOYMENT_URL=https://your-deployment-name.crewai.com
CREWAI_DEPLOYMENT_TOKEN=...
