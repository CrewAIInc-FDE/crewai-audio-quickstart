# ---- client-side (client/ask.py) ----------------------------------------

# Used by the client for the speech-to-text call to OpenAI's transcription API.
# (Alternative: put the key in ~/.openai-key instead.)
# The DEPLOYED crew reads its own OPENAI_API_KEY from the env vars you set on
# the deployment in CrewAI AMP — stored on the platform, never in this repo.
OPENAI_API_KEY=sk-...

# Both values are shown on your deployment's page in CrewAI AMP after you
# deploy. Every deployment has its OWN url and its OWN bearer token.
CREWAI_DEPLOYMENT_URL=https://your-deployment-name.crewai.com
CREWAI_DEPLOYMENT_TOKEN=...
